# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///ecommerce.db

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ACCESS_TOKEN_EXPIRES=3600

# Groq LLM API
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Pinecone Vector Database
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-environment
PINECONE_INDEX_NAME=ecommerce-products

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Non-Hallucination Policy Configuration
# Min confidence score for KB answers (0-10 token overlap score)
# Default: 2 (strict)
# Lower values = more KB answers but lower quality
# Higher values = only high-confidence KB answers (recommended for production)
KB_CONFIDENCE_THRESHOLD=2

# Allow LLM to handle support queries when KB threshold not met
# Default: true (LLM fallback with context injection)
# Set to false for strict KB-only mode (no LLM for support queries)
ALLOW_LLM_FOR_SUPPORT_QUERIES=true
